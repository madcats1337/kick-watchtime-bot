# Discord Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_discord_server_id_here

# Kick Configuration
KICK_CHANNEL=your_kick_channel_name_here

# Public host of THIS bot deployment. Used to build the Kick webhook callback URL
# (BOT_PUBLIC_URL/webhooks/kick) that Kick posts go-live events to. MUST match the
# deployment's real public domain — if it's wrong or unset, Kick delivers go-live
# webhooks to a dead URL and live announcements silently stop firing.
BOT_PUBLIC_URL=https://bot.wagerlabs.app

# Twitch Configuration (parity with Kick — live notifications + chat)
# App credentials from https://dev.twitch.tv/console/apps. The dashboard handles
# OAuth + EventSub registration; the bot needs these to send chat (Helix) and to
# verify/forward EventSub events.
# TWITCH_CLIENT_ID=your_twitch_client_id_here
# TWITCH_CLIENT_SECRET=your_twitch_client_secret_here
# TWITCH_REDIRECT_URI=https://bot.wagerlabs.app/auth/twitch/callback
# Twitch user id of the bot account that reads/sends chat (user:read:chat,
# user:write:chat, user:bot; broadcaster grants channel:bot).
# TWITCH_BOT_USER_ID=your_twitch_bot_account_user_id
# REDIS_URL is required to forward Twitch chat from the webhook process to the bot.
# REDIS_URL=redis://localhost:6379

# Optional: Set this to bypass Cloudflare issues on cloud platforms
# Find your chatroom ID by running locally first, or checking browser dev tools
# KICK_CHATROOM_ID=123456

# Database Configuration
# For local development (SQLite):
# DATABASE_URL=sqlite:///watchtime.db

# For cloud deployment (PostgreSQL):
# DATABASE_URL=postgresql://username:password@host:port/database
# Example for Railway: postgresql://postgres:password@containers-us-west-123.railway.app:5432/railway
# Example for Heroku: postgres://user:pass@host:5432/dbname
# Example for Supabase: postgresql://postgres:password@db.project.supabase.co:5432/postgres

# Bot Configuration
WATCH_INTERVAL_SECONDS=60
ROLE_UPDATE_INTERVAL_SECONDS=600
CODE_EXPIRY_MINUTES=10
